# Enable debug logging
DEBUG=false

# Atlassian Configuration (required for Jira access)
# Your Jira site name (for https://your-instance.atlassian.net)
ATLASSIAN_SITE_NAME=your-instance
# Your Atlassian account email
ATLASSIAN_USER_EMAIL=your-email@example.com  
# Your Atlassian API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
ATLASSIAN_API_TOKEN=

# Tempo Cloud (optional — enables tempo_get / tempo_post / … MCP tools)
# Create token: Jira → Tempo → Settings → Data Access → API Integration
TEMPO_API_TOKEN=YOUR_TEMPO_API_TOKEN
# Base URL for Tempo REST API v4 (no trailing slash)
TEMPO_API_BASE_URL=https://api.tempo.io/4
